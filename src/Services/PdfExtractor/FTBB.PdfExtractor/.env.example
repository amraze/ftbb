# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DEFAULT_EXPIRY=86400

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE_NAME=pdf_downloaded_queue
RABBITMQ_EXCHANGE_NAME=ftbb_event_bus
RABBITMQ_BINDING_KEY=#
RABBITMQ_HEARTBEAT=600
RABBITMQ_BLOCKED_TIMEOUT=300
RABBITMQ_PREFETCH_COUNT=1
RABBITMQ_DURABLE_QUEUE=true
RABBITMQ_DURABLE_EXCHANGE=true

# Logging
LOG_LEVEL=INFO
